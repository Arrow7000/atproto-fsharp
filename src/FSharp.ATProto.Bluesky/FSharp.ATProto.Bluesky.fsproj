<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Description>Native F# client for Bluesky and the AT Protocol. Type-safe, functional-first, exception-free. Posts, social graph, chat, feeds, profiles, notifications, moderation, and full XRPC access via 237 typed endpoint wrappers generated from 324 Lexicon schemas.</Description>
  </PropertyGroup>
  <ItemGroup>
    <Compile Include="Generated/Generated.fs" />
    <Compile Include="PostExtensions.fs" />
    <Compile Include="RichText.fs" />
    <Compile Include="Identity.fs" />
    <Compile Include="Bluesky.fs" />
    <Compile Include="Chat.fs" />
    <Compile Include="Ozone.fs" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\FSharp.ATProto.Syntax\FSharp.ATProto.Syntax.fsproj" />
    <ProjectReference Include="..\FSharp.ATProto.DRISL\FSharp.ATProto.DRISL.fsproj" />
    <ProjectReference Include="..\FSharp.ATProto.Core\FSharp.ATProto.Core.fsproj" />
    <ProjectReference Include="..\FSharp.ATProto.Streaming\FSharp.ATProto.Streaming.fsproj" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="FSharp.SystemTextJson" Version="1.4.36" />
  </ItemGroup>
</Project>
